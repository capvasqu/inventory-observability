# inventory-observability — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Anthropic (required for AI analysis) ──────────────────────────────────────
# Same key as incident-agent (Project 5) — NOT the OAuth token
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── GitHub (required for Issue creation) ──────────────────────────────────────
# Personal Access Token — scope: repo (includes issues + actions read)
# Create at: github.com/settings/tokens
GITHUB_TOKEN=github_pat_your-token-here

# ── Slack (optional — set enabled: true in config.yaml) ──────────────────────
# Create at: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Alert threshold overrides (optional — override config.yaml) ──────────────
# ALERT_ERROR_RATE_WARN=5
# ALERT_ERROR_RATE_CRIT=15
# ALERT_LATENCY_P95_WARN=500
# ALERT_LATENCY_P95_CRIT=2000
# ALERT_DB_POOL_WARN=80
# ALERT_DB_POOL_CRIT=95
# MONITORING_INTERVAL=30
